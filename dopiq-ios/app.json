{
  "expo": {
    "name": "Dopiq",
    "slug": "dopiq",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAFAF8"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.dopiq.app",
      "buildNumber": "1",
      "associatedDomains": ["applinks:dopiqapp.com"],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "scheme": "dopiq",
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#FAFAF8"
      },
      "package": "com.dopiq.app"
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "extra": {
      "eas": {
        "projectId": "49a4e55b-83d7-473b-9123-c158a825c7cd"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/49a4e55b-83d7-473b-9123-c158a825c7cd"
    },
    "plugins": [
      [
        "react-native-iap",
        {
          "paymentProvider": "Apple AppStore"
        }
      ]
    ]
  }
}