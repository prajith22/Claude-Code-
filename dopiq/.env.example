# Supabase Postgres
#
# Two URLs are required:
#
#   DATABASE_URL — pooled, used by the app at runtime. Points at the
#     Supabase PgBouncer pooler in TRANSACTION mode (port 6543).
#     `pgbouncer=true` tells Prisma not to use named prepared statements
#     (transaction mode invalidates them). `connection_limit=1` caps
#     each serverless instance at one open connection so Vercel can
#     spin up dozens of functions without exhausting Supabase's
#     pool_size (Vercel hit `EMAXCONNSESSION` on /tickets routes
#     without this).
#
#   DIRECT_URL — non-pooled, used ONLY by `prisma migrate` /
#     `prisma db push` / `prisma studio`. Points straight at the
#     primary on port 5432. Schema migrations can't run through
#     PgBouncer transaction mode because they use session-level
#     features (advisory locks, DDL).
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Sign in with Apple. APPLE_ID is the Services ID from Apple Developer
# (e.g., com.dopiq.app.signin). The other three are pieces used to
# generate the ES256 client_secret JWT at request time inside
# lib/auth.ts — no manual JWT rotation needed.
#   - APPLE_TEAM_ID:     10-char team ID from Apple Developer
#   - APPLE_KEY_ID:      10-char Key ID for the Sign in with Apple key
#   - APPLE_PRIVATE_KEY: contents of the AuthKey_<KEYID>.p8 file,
#                        base64-encoded so newlines survive Vercel paste.
APPLE_ID=""
APPLE_TEAM_ID=""
APPLE_KEY_ID=""
APPLE_PRIVATE_KEY=""

# Apple In-App Purchase shared secret. Used to authenticate calls
# to Apple's verifyReceipt endpoint when activating IAP-sourced
# subscriptions. Generate it in App Store Connect under:
#   My Apps → Dopiq → App Information → App-Specific Shared Secret
# (a single 32-character hex string). Same value works for both
# the production and sandbox verifyReceipt endpoints.
APPLE_IAP_SHARED_SECRET=""

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Per-plan price IDs from the Stripe dashboard. All plans use a 7-day
# trial configured at checkout time (no Stripe-side trial config needed).
STRIPE_LITE_PRICE_ID=""
STRIPE_PLUS_PRICE_ID=""
STRIPE_PRO_PRICE_ID=""
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# The Odds API (https://the-odds-api.com) — powers live football/basketball odds on /bet
ODDS_API_KEY=""

# Resend (https://resend.com) — transactional email for verification.
# RESEND_FROM_EMAIL must be on a domain you've verified in the Resend
# dashboard (e.g., noreply@dopiqapp.com).
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@dopiqapp.com"
